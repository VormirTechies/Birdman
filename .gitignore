# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.playwright
*.spec.ts-snapshots
playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sensitive / secrets
# Firebase service account and admin keys
firebase-adminsdk*.json
serviceAccount*.json
google-credentials.json
gcloud-service-account.json
firebase-debug.log
.firebase/
# Google Android / iOS config (may contain identifiers)
google-services.json
GoogleService-Info.plist

# Supabase exports / local config
.supabase/
supabase-export/

# Private keys / keystores
*.key
*.jks
*.p12

# IDE / editor
.vscode/
.idea/

# Local credentials and secret files
credentials.json
secret*.json
secrets.json
